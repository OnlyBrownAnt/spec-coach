{
  "name": "spec-coach",
  "version": "2.1.1",
  "description": "SDD that trusts AI. Guidance over gates. Craftsmanship over compliance.",
  "type": "module",
  "bin": {
    "spec-coach": "./bin/cli.mjs"
  },
  "files": [
    "agents.json",
    "bin/",
    "skills/",
    "templates/",
    "scripts/",
    "src/"
  ],
  "scripts": {
    "init": "npx tsx src/cli.ts init --agent claude",
    "test": "bash tests/run.sh",
    "test:l2": "bash tests/run.sh l2",
    "test:all": "bash tests/run.sh all",
    "test:verbose": "bash tests/run.sh --verbose",
    "test:results": "bash tests/run.sh results"
  },
  "dependencies": {
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "sdd",
    "spec-driven-development",
    "ai-coding",
    "spec-coach",
    "claude-code",
    "cursor",
    "copilot"
  ],
  "license": "MIT",
  "repository": "https://github.com/OnlyBrownAnt/spec-coach"
}
